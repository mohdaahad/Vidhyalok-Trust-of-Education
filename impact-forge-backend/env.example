# ============================================
# Vidhyalok Trust of Education - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ============================================
# Database Configuration
# ============================================
# MySQL Connection Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=impact_forge
DB_USER=root
DB_PASSWORD=

# ============================================
# Admin Configuration
# ============================================
ADMIN_EMAIL=[EMAIL_ADDRESS]
ADMIN_PASSWORD=


# ============================================
# JWT Authentication Configuration
# ============================================
# Generate a strong random secret key for JWT tokens
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-characters
JWT_EXPIRE=7d

# ============================================
# Email Configuration (Nodemailer)
# ============================================
# Gmail SMTP Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=noreply@vidhyaloktrust.org

# ============================================
# Development/Testing
# ============================================
# Set to 'true' to enable detailed error logging
DEBUG=false

# ============================================
# Notes:
# ============================================
# 1. Never commit the .env file to version control
# 2. Use different .env files for development, staging, and production
# 3. Keep all secrets secure and rotate them regularly
# 4. For production, use environment variables provided by your hosting platform
# 5. Minimum JWT_SECRET length should be 32 characters
# 6. Use strong, unique passwords for all services
